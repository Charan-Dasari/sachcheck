#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# -------------------------------------------------------
# SENSITIVE FILES - DO NOT UPLOAD TO GITHUB
# -------------------------------------------------------

# Firebase config files (contain API keys & project secrets)
**/google-services.json
**/GoogleService-Info.plist

# Android local machine config (contains local SDK path)
android/local.properties

# Android Gradle cache and build files
android/.gradle/
android/.kotlin/
android/build/
android/app/build/

# Dart/Flutter generated files
.flutter-plugins
*.g.dart
*.freezed.dart

# Environment / secret files
.env
.env.*
secrets.dart
lib/secrets.dart
lib/config/secrets.dart

# iOS derived data & build artifacts
ios/Pods/
ios/.symlinks/
ios/build/
ios/DerivedData/

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
